{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/pipeline/trigger.ts": {
      "maxDuration": 300,
      "memory": 2048
    },
    "api/pipeline/clickup-webhook.ts": {
      "maxDuration": 60
    },
    "api/pipeline/tier2-trigger.ts": {
      "maxDuration": 300,
      "memory": 2048
    },
    "api/pipeline/tier2-reset.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/pipeline/trigger",
      "schedule": "0 6 * * 1"
    }
  ]
}
