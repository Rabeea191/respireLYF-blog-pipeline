# Copy to .env and fill in values
# Never commit .env to git

# ─── Anthropic (Claude) ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── SerpAPI — Google Trends + competitor search ──────────────────
# Get free key at: serpapi.com (100 searches/month free)
SERP_API_KEY=your-serpapi-key

# ─── Reddit API — r/Asthma, r/COPD trend signals ─────────────────
# Get at: reddit.com/prefs/apps → create app → Script type
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=RespireLYF-Pipeline/1.0

# ─── ClickUp — human approval workflow ───────────────────────────
CLICKUP_API_KEY=pk_...
CLICKUP_LIST_ID=901817388194
CLICKUP_WORKSPACE_ID=90181139906
CLICKUP_WEBHOOK_SECRET=your-webhook-secret
CLICKUP_STATUS_PENDING=To Review
CLICKUP_STATUS_APPROVED=Approved
CLICKUP_STATUS_APPROVED_NOTES=Approved - Needs Tweak
CLICKUP_STATUS_REJECTED=Rejected

# ─── Payload CMS — blog posting ──────────────────────────────────
PAYLOAD_URL=https://www.respirelyf.com
PAYLOAD_EMAIL=admin@respirelyf.com
PAYLOAD_PASSWORD=your-payload-admin-password

# ─── NanoBananaAPI (Gemini 2.5 Flash Image) — inline blog images ─
# Optional. If unset, Tier 2 still posts drafts — just without images.
# Get key at: https://nanobananaapi.ai
NANO_BANANA_API_KEY=your-nanobanana-api-key
# NANO_BANANA_BASE_URL=https://api.nanobananaapi.ai/api/v1/nanobanana

# ─── Pipeline Config ─────────────────────────────────────────────
APPROVAL_THRESHOLD=3
MAX_TOPIC_RETRIES=3
CRON_SECRET=your-random-cron-secret

# ─── Deployment URL (Vercel sets VERCEL_URL automatically) ──────
# Override only for custom domains. Used by the ClickUp webhook to
# call the Tier 2 trigger endpoint back on the same deployment.
# PIPELINE_BASE_URL=https://blog-pipeline.respirelyf.com
